# ViralClip AI — Environment Variables
# Copy this to .env and fill in your values

# === REQUIRED ===
GROQ_API_KEY=your_groq_api_key_here

# === OPTIONAL: App Settings ===
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# === Processing Settings ===
MAX_CONCURRENT_JOBS=2
TEMP_DIR=./temp
EXPORT_DIR=./exports
ASSETS_DIR=./assets
MODELS_DIR=./models

# === Whisper Settings ===
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# === Clip Settings ===
DEFAULT_CLIP_MIN_DURATION=30
DEFAULT_CLIP_MAX_DURATION=60
DEFAULT_NUM_CLIPS=5
DEFAULT_CAPTION_STYLE=hormozi
DEFAULT_BACKGROUND=subway

# === Export Settings ===
EXPORT_WIDTH=1080
EXPORT_HEIGHT=1920
EXPORT_FPS=30
EXPORT_VIDEO_BITRATE=8M
EXPORT_AUDIO_BITRATE=192k

# === CORS ===
FRONTEND_URL=http://localhost:3000
